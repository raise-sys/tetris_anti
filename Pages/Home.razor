        public static int[,] GetShapeMatrix(int type)
        {
            int[,] source = Tetrominoes[type];
            int size = source.GetLength(0);
            int[,] copy = new int[size, size];
            Array.Copy(source, copy, source.Length);
            return copy;
        }
